{
  "compilerOptions": {
    "outDir": "./dist",
    "sourceMap": true,
    "noImplicitAny": true,
    "declaration": true,
    "module": "commonjs",
    "target": "ES2017",
    "lib": ["DOM", "ES2017"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["./src/**/*"]
}
