{
  "name": "react-core-ts",
  "version": "4.0.5",
  "description": "React Components",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/react-core-ts.css",
  "sideEffects": [
    "./dist/index.js",
    "./dist/injectStyles.js",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/react-core-ts.css",
    "./package.json": "./package.json",
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "start": "webpack serve --open --mode development",
    "build:styles": "node scripts/build-styles.js",
    "build": "npm run build:styles && tsc && rm -rf dist/styles && cp -R src/styles dist/styles",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rajeshbala2020/react-components.git"
  },
  "keywords": [
    "react",
    "components",
    "textfield",
    "autocomplete"
  ],
  "author": "rajeshbala",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Rajeshbala2020/react-components/issues"
  },
  "homepage": "https://github.com/Rajeshbala2020/react-components#readme",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.23.0",
    "@svgr/webpack": "^8.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^8.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.2",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.47",
    "postcss-loader": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "ts-loader": "^9.4.4",
    "typescript": "^5.7.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^3.11.3"
  },
  "dependencies": {
    "@babel/plugin-transform-typescript": "^7.22.15",
    "react-hook-form": "^7.53.1",
    "source-map-loader": "^4.0.1"
  }
}
